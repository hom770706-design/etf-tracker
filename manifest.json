{
  "manifest_version": 3,
  "name": "台灣主動ETF成分股追蹤器",
  "version": "1.3.0",
  "description": "每日追蹤 16 檔主動式 ETF 成分股變化與趨勢分析",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "alarms",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.twse.com.tw/*",
    "https://wwwc.twse.com.tw/*",
    "https://isin.twse.com.tw/*",
    "https://openapi.twse.com.tw/*",
    "https://www.pocket.tw/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*",
    "https://api.groq.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.pocket.tw/etf/tw/*/fundholding"
      ],
      "js": ["content/extract.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "主動ETF成分股追蹤器"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
